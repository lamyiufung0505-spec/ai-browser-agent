# ===== 复制本文件为 .env 后填写（.env 不会被提交到仓库）=====

# 【必填】DeepSeek 决策大脑用的 Key
# 申请地址：https://platform.deepseek.com/
# 没有就跑不起来
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 【一般不用改】DeepSeek 接口地址与模型名
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== 下面三项：仅在需要"识别图片形式验证码"时填写，普通任务可留空 =====
# 任意 OpenAI 兼容的视觉接口都行：
#   OpenAI 官方：  VISION_BASE_URL=https://api.openai.com/v1  VISION_MODEL=gpt-4o-mini
#   本地免费(Ollama 跑 llama3.2-vision)：VISION_BASE_URL=http://localhost:11434/v1  VISION_API_KEY=ollama  VISION_MODEL=llama3.2-vision
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini

# ===== 可选 =====
# 默认最大步数（防失控），命令行 --max-steps 可临时覆盖
MAX_STEPS=15
# 是否默认无头模式（true/false）。命令行加 --headless 也能临时开启
HEADLESS=false
